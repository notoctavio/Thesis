# Normalize text files to LF in repository
* text=auto eol=lf

# Keep Windows scripts with CRLF if ever added
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python and shell scripts
*.py text eol=lf
*.sh text eol=lf

# Markdown, YAML, JSON, CSV
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.csv text eol=lf

# Jupyter notebooks: treat as text (JSON) and improve PR readability
*.ipynb text diff=python

# Binary data/model artifacts
*.mat binary
*.zip binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pt binary
*.pth binary
*.h5 binary
*.hdf5 binary
*.pkl binary
*.joblib binary
